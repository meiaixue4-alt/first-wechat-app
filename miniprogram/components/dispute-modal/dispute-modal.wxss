/* 遮罩层 — 淡入 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

/* 弹窗 — 底部滑入 */
.modal {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background-color: var(--color-bg-surface, #161b22);
  border-top: 1px solid var(--color-border, #30363d);
  border-radius: 2rpx;
  padding: 40rpx 32rpx;
  overflow-y: auto;
  animation: slideUp 200ms ease-out;
}

.modal-closing {
  animation: slideDown 150ms ease-in;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

@keyframes slideDown {
  from { transform: translateY(0); }
  to   { transform: translateY(100%); }
}

.modal-title {
  display: block;
  font-family: var(--font-title);
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.modal-sub {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 关闭按钮 */
.modal-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 36rpx;
  color: var(--color-text-muted);
  font-family: var(--font-mono);
  padding: 8rpx;
}

/* 标签 */
.label {
  display: block;
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 24rpx;
  margin-bottom: 8rpx;
  letter-spacing: 0.5px;
}

.required {
  color: var(--color-warning);
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 140rpx;
  background-color: var(--color-bg-elevated, #1c2128);
  border: 1px solid var(--color-border, #30363d);
  border-radius: 2rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-body);
  line-height: 1.6;
  caret-color: var(--color-accent, #58a6ff);
  box-sizing: border-box;
}

.textarea-placeholder {
  color: var(--color-text-muted);
  font-size: 24rpx;
}

/* 附件上传 */
.attachment-area {
  margin-top: 8rpx;
}

.attach-btn {
  display: inline-flex;
  align-items: center;
  border: 1px dashed var(--color-border, #30363d);
  border-radius: 2rpx;
  padding: 12rpx 24rpx;
}

.attach-plus {
  font-family: var(--font-mono);
  font-size: 28rpx;
  color: var(--color-text-muted);
  margin-right: 8rpx;
}

.attach-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.attach-preview {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: var(--color-bg-elevated, #1c2128);
  border-radius: 2rpx;
}

.attach-img {
  width: 60rpx;
  height: 60rpx;
  border-radius: 2rpx;
  margin-right: 12rpx;
}

.attach-name {
  flex: 1;
  font-size: 22rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attach-remove {
  font-family: var(--font-mono);
  font-size: 28rpx;
  color: var(--color-warning);
  padding: 8rpx;
}

/* 身份选项 */
.identity-group {
  display: flex;
  flex-direction: column;
}

.identity-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.identity-label {
  font-size: 26rpx;
  color: var(--color-text-body);
  margin-left: 12rpx;
}

.identity-active .identity-label {
  color: var(--color-accent);
}

/* 自定义 radio */
.radio {
  width: 32rpx;
  height: 32rpx;
  border: 1.5px solid var(--color-border, #30363d);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.radio-checked {
  border-color: var(--color-accent);
}

.radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-accent);
}

/* 操作按钮 */
.modal-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 32rpx;
  gap: 16rpx;
}

.btn-cancel {
  padding: 14rpx 32rpx;
  border: 1px solid var(--color-border);
  border-radius: 2rpx;
  transition: background-color 100ms ease-out;
}

.btn-cancel-hover {
  background-color: var(--color-bg-elevated);
}

.btn-cancel-text {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.btn-submit {
  padding: 14rpx 32rpx;
  background-color: var(--color-accent);
  border-radius: 2rpx;
  transition: opacity 100ms ease-out;
}

.btn-submit-hover {
  opacity: 0.85;
}

.btn-submit-text {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}
