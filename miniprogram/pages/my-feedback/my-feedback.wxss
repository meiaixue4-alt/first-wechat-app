.page {
  padding: 0 var(--spacing-page);
  min-height: 100vh;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 0.5px solid var(--color-border);
  transition: background-color 100ms ease-out;
}

.list-item-active {
  background-color: var(--color-bg-elevated);
}

.item-main {
  flex: 1;
}

.item-header {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 4rpx;
}

.item-reason {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-body);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.item-meta {
  font-family: var(--font-mono);
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.item-arrow {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-left: 12rpx;
  margin-top: 8rpx;
}

.empty {
  padding-top: 160rpx;
  text-align: center;
}

.empty-text {
  display: block;
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}
