<!-- Tips 详情页 -->
<view class="page">
  <block wx:if="{{tip}}">
    <!-- 分类编号 -->
    <text class="detail-category">[{{categoryMap[tip.category].id}}] {{categoryMap[tip.category].name}}</text>

    <!-- 一句话结论 -->
    <text class="detail-title">{{tip.title}}</text>

    <!-- 日期 -->
    <text class="detail-date">{{tip.date}}</text>

    <view class="divider"></view>

    <!-- 正文 -->
    <view class="detail-body">
      <text class="body-text">{{tip.body}}</text>
    </view>

    <!-- 参考文献 -->
    <view class="references" wx:if="{{tip.references.length}}">
      <text class="ref-title">参考文献</text>
      <view class="ref-list">
        <text class="ref-item" wx:for="{{tip.references}}" wx:key="index">[{{index + 1}}] {{item}}</text>
      </view>
    </view>

    <view class="divider" style="margin: 32rpx 0;"></view>

    <!-- 互动操作栏 -->
    <view class="action-bar">
      <!-- 第一行：态度表态 — 药丸按钮 -->
      <view class="action-attitude">
        <view class="pill-btn {{usefulDone ? 'pill-useful-done' : ''}}" bindtap="onUseful" hover-class="pill-useful-hover">
          <text class="pill-icon">👍</text>
          <text class="pill-label">有用</text>
          <text class="pill-count" wx:if="{{tip.usefulCount}}">{{tip.usefulCount}}</text>
        </view>
        <view class="pill-btn" bindtap="onNotInterested" hover-class="pill-neutral-hover">
          <text class="pill-icon">👎</text>
          <text class="pill-label">不感兴趣</text>
        </view>
        <view class="pill-btn" bindtap="onDispute" hover-class="pill-dispute-hover">
          <text class="pill-icon">⚠️</text>
          <text class="pill-label">质疑</text>
        </view>
      </view>
      <!-- 第二行：内容行为 -->
      <view class="action-behavior">
        <view class="behavior-half">
          <view class="text-btn {{isFav ? 'text-fav-active' : ''}}" bindtap="onToggleFav" hover-class="text-btn-hover">
            <text class="text-btn-icon">{{isFav ? '★' : '☆'}}</text>
            <text class="text-btn-label">收藏</text>
          </view>
        </view>
        <view class="behavior-half">
          <button class="text-btn share-btn" open-type="share" hover-class="text-btn-hover">
            <text class="text-btn-icon">↗</text>
            <text class="text-btn-label">转发</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 底部引流 -->
    <view class="lead-in" bindtap="goHome">
      <text class="lead-text">来自「格物致知」小程序</text>
      <text class="lead-link">去看看今天的 Tips</text>
    </view>
  </block>

  <!-- 加载中 -->
  <view class="loading" wx:else>
    <text class="loading-text">加载中…</text>
  </view>

  <!-- 质疑弹窗 -->
  <dispute-modal
    visible="{{showDispute}}"
    tip-id="{{disputeTipId}}"
    bindcancel="onDisputeCancel"
    bindsubmit="onDisputeSubmit"
  />
</view>
