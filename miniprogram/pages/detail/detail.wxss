.page {
  padding: 0 var(--spacing-page);
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.detail-category {
  display: block;
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 1px;
  padding-top: 24rpx;
}

.detail-title {
  display: block;
  font-family: var(--font-title);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
  margin-top: 16rpx;
}

.detail-date {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.divider {
  height: 1px;
  background-color: var(--color-border);
  margin: 24rpx 0;
}

/* 正文 */
.body-text {
  font-size: 28rpx;
  color: var(--color-text-body);
  line-height: 1.8;
  white-space: pre-line;
}

/* 参考文献 */
.references {
  margin-top: var(--spacing-block);
  padding: 12rpx 16rpx;
  background-color: rgba(88, 166, 255, 0.08);
  border-left: 2px solid var(--color-quote-bar);
}

.ref-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.ref-list {
  margin-top: 8rpx;
}

.ref-item {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-top: 4rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  align-items: center;
}

.action-btn {
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--color-text-muted);
  transition: color 150ms ease-out;
  padding: 4rpx 0;
}

.action-dispute {
  /* 默认态同其他按钮 */
}

.action-sep {
  margin: 0 10rpx;
  color: var(--color-text-muted);
  font-family: var(--font-mono);
}

/* 按钮悬浮/按压态 */
.action-btn-useful-hover {
  color: var(--color-positive);
}

.action-btn-dispute-hover {
  color: var(--color-warning);
}

.action-btn-fav-hover {
  color: var(--color-text-primary);
}

.action-btn-neutral-hover {
  color: var(--color-text-body);
}

/* 按钮激活态 */
.useful-done {
  color: var(--color-positive);
}

.fav-active {
  color: var(--color-text-primary);
}

/* 转发按钮 — 覆盖原生 button 样式 */
.share-btn {
  display: inline;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.share-btn::after {
  border: none;
}

/* 底部引流 */
.lead-in {
  margin-top: 48rpx;
  padding-top: 24rpx;
  border-top: 1px solid var(--color-border);
  text-align: center;
}

.lead-text {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.lead-link {
  display: block;
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--color-accent);
  margin-top: 8rpx;
  letter-spacing: 0.5px;
}

/* 加载 */
.loading {
  padding-top: 160rpx;
  text-align: center;
}

.loading-text {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
}
