.page {
  padding: 0 var(--spacing-page);
  min-height: 100vh;
  padding-bottom: 48rpx;
}

.detail-category {
  display: block;
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 1px;
  padding-top: 24rpx;
}

.detail-title {
  display: block;
  font-family: var(--font-title);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
  margin-top: 16rpx;
}

.detail-date {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.divider {
  height: 1px;
  background-color: var(--color-border);
  margin: 24rpx 0;
}

/* 正文 */
.body-text {
  font-size: 28rpx;
  color: var(--color-text-body);
  line-height: 1.8;
  white-space: pre-line;
}

/* 参考文献 */
.references {
  margin-top: var(--spacing-block);
  padding: 12rpx 16rpx;
  background-color: rgba(88, 166, 255, 0.08);
  border-left: 2px solid var(--color-quote-bar);
}

.ref-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.4;
}

.ref-list {
  margin-top: 8rpx;
}

.ref-item {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-top: 4rpx;
}

/* ===== 操作栏 ===== */
.action-bar {
  margin-top: 8rpx;
}

/* --- 第一行：态度表态 · 药丸按钮 --- */
.action-attitude {
  display: flex;
  justify-content: space-between;
}

.pill-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 22rpx;
  border-radius: 36rpx;
  background-color: var(--color-bg-surface);
  border: 1px solid var(--color-border);
  transition: all 150ms ease-out;
}

.pill-icon {
  font-size: 26rpx;
  margin-right: 4rpx;
  line-height: 1;
}

.pill-label {
  font-size: 24rpx;
  color: var(--color-text-body);
  font-family: var(--font-body);
  line-height: 1;
}

.pill-count {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
  font-family: var(--font-mono);
  line-height: 1;
}

/* 有用 — 常态 & 激活 */
.pill-useful-done {
  background-color: rgba(63, 185, 80, 0.12);
  border-color: rgba(63, 185, 80, 0.35);
}
.pill-useful-done .pill-label,
.pill-useful-done .pill-count {
  color: var(--color-positive);
}

.pill-useful-hover {
  background-color: rgba(63, 185, 80, 0.08);
  border-color: rgba(63, 185, 80, 0.25);
}

/* 不感兴趣 */
.pill-neutral-hover {
  background-color: var(--color-bg-elevated);
}

/* 质疑 */
.pill-dispute-hover {
  background-color: rgba(217, 83, 79, 0.08);
  border-color: rgba(217, 83, 79, 0.25);
}

/* --- 第二行：内容行为 · 描边药丸 --- */
.action-behavior {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

.behavior-half {
  width: 50%;
  display: flex;
  justify-content: center;
}

.text-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  padding: 14rpx 0;
  border-radius: 36rpx;
  border: 1px solid var(--color-border);
  background-color: transparent;
  line-height: 1;
  transition: all 150ms ease-out;
}

.text-btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.text-btn-label {
  font-size: 30rpx;
  color: var(--color-text-muted);
  font-family: var(--font-body);
  line-height: 1;
}

.text-btn-hover {
  background-color: var(--color-bg-surface);
  border-color: var(--color-text-muted);
}

/* 收藏激活态 */
.text-fav-active {
  border-color: rgba(88, 166, 255, 0.35);
  background-color: rgba(88, 166, 255, 0.08);
}
.text-fav-active .text-btn-icon,
.text-fav-active .text-btn-label {
  color: var(--color-accent);
}

/* 转发 — 覆盖原生 button 样式 */
.share-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  width: 180rpx !important;
  padding: 14rpx 0 !important;
  margin: 0 !important;
  border-radius: 36rpx !important;
  border: 1px solid var(--color-border) !important;
  background-color: transparent !important;
  line-height: 1 !important;
  box-sizing: content-box !important;
  transition: all 150ms ease-out !important;
}
.share-btn.text-btn-hover {
  background-color: var(--color-bg-surface) !important;
  border-color: var(--color-text-muted) !important;
}
.share-btn::after {
  border: none !important;
}

/* 底部引流 */
.lead-in {
  margin-top: 48rpx;
  padding-top: 24rpx;
  border-top: 1px solid var(--color-border);
  text-align: center;
}

.lead-text {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.lead-link {
  display: block;
  font-family: var(--font-mono);
  font-size: 24rpx;
  color: var(--color-accent);
  margin-top: 8rpx;
  letter-spacing: 0.5px;
}

/* 加载 */
.loading {
  padding-top: 160rpx;
  text-align: center;
}

.loading-text {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-text-muted);
}
