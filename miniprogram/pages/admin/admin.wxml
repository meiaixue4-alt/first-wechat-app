<!-- 管理端 -->
<view class="page">
  <!-- 密码验证 -->
  <view class="lock" wx:if="{{!unlocked}}">
    <text class="lock-title">管理端</text>
    <input class="lock-input" type="text" password placeholder="输入管理密码" value="{{pwd}}" bindinput="onPwdInput" bindconfirm="onUnlock" />
    <button class="lock-btn" bindtap="onUnlock">进入</button>
    <text class="lock-err" wx:if="{{pwdErr}}">密码错误</text>
  </view>

  <!-- 管理面板 -->
  <block wx:else>
    <view class="header">
      <text class="header-title">内容管理</text>
      <view class="header-right">
        <text class="cloud-status {{cloudStatus}}">{{cloudStatusText}}</text>
        <text class="header-count">共 {{total}} 条</text>
      </view>
    </view>

    <!-- 新增表单 -->
    <view class="form-card">
      <text class="form-title">{{editId ? '编辑' : '新增'}} Tip</text>

      <view class="form-row">
        <text class="form-label">分类</text>
        <picker mode="selector" range="{{categoryNames}}" value="{{categoryIdx}}" bindchange="onCategoryChange">
          <view class="form-picker">{{categoryNames[categoryIdx] || '请选择'}}</view>
        </picker>
      </view>

      <view class="form-row">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
          <view class="form-picker">{{form.date || '请选择'}}</view>
        </picker>
      </view>

      <view class="form-row">
        <text class="form-label">标题 (≤15字)</text>
        <input class="form-input" value="{{form.title}}" bindinput="onFieldInput" data-field="title" placeholder="一句话结论" />
      </view>

      <view class="form-row">
        <text class="form-label">卡片摘要</text>
        <textarea class="form-textarea" value="{{form.summary}}" bindinput="onFieldInput" data-field="summary" placeholder="2-3句简短解释" />
      </view>

      <view class="form-row">
        <text class="form-label">正文</text>
        <textarea class="form-textarea form-textarea-lg" value="{{form.body}}" bindinput="onFieldInput" data-field="body" placeholder="完整正文，多段落用换行分隔" />
      </view>

      <view class="form-row">
        <text class="form-label">配图URL (可选)</text>
        <input class="form-input" value="{{form.image}}" bindinput="onFieldInput" data-field="image" placeholder="图片链接" />
      </view>

      <view class="form-row">
        <text class="form-label">参考文献 (一行一条)</text>
        <textarea class="form-textarea" value="{{form.referencesText}}" bindinput="onFieldInput" data-field="referencesText" placeholder="GB 4806.7-2016 食品安全国家标准..." />
      </view>

      <view class="form-row">
        <text class="form-label">有用数</text>
        <input class="form-input" type="number" value="{{form.usefulCount}}" bindinput="onFieldInput" data-field="usefulCount" placeholder="0" />
      </view>

      <view class="form-actions">
        <button class="btn-submit" bindtap="onSubmit" loading="{{submitting}}">{{editId ? '更新' : '新增'}}</button>
        <button class="btn-cancel" bindtap="onCancelEdit" wx:if="{{editId}}">取消编辑</button>
      </view>
    </view>

    <!-- 已有列表 -->
    <view class="list-header">
      <text>已有内容</text>
      <view class="list-header-actions">
        <button class="btn-import" bindtap="onImportMock" loading="{{importing}}" size="mini">导入Mock</button>
        <button class="btn-dedup" bindtap="onRemoveDuplicates" size="mini">清除重复</button>
        <button class="btn-clear-cache" bindtap="onClearCache" size="mini">清缓存</button>
      </view>
    </view>
    <view class="import-progress" wx:if="{{importProgress}}">{{importProgress}}</view>
    <view class="tip-item" wx:for="{{tips}}" wx:key="_id">
      <view class="tip-meta">
        <text class="tip-cat">{{categoryMap[item.category].name}}</text>
        <text class="tip-date">{{item.date}}</text>
      </view>
      <text class="tip-title">{{item.title}}</text>
      <view class="tip-actions">
        <text class="tip-action" bindtap="onEdit" data-id="{{item._id}}">编辑</text>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}">
      <button class="btn-more" bindtap="onLoadMore" loading="{{loadingMore}}">加载更多</button>
    </view>
  </block>
</view>
